# Quant System Dry-run Runtime Environment
# Copy to .env and configure

# Mode (DANGEROUS: do not change)
QQ_MODE=DRY_RUN
QQ_SUBMIT_PERMISSION=NO_SUBMIT
QQ_DRY_RUN=true
QQ_REAL_TRADING_ALLOWED=false
QQ_TESTNET_SUBMIT_ALLOWED=false

# Logging
QQ_LOG_LEVEL=INFO
QQ_LOG_DIR=./logs

# Dashboard
QQ_DASHBOARD_OUTPUT=./reports/operator_dashboard.html
